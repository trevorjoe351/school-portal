generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Resource {
  id        Int      @id @default(autoincrement())
  title     String
  subject   String
  form      String
  createdAt DateTime @default(now())
}