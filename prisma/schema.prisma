generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Resource {
  id          Int      @id @default(autoincrement())

  title       String
  description String?

  subject     String
  form        String

  fileName    String
  filePath    String
  fileType    String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}